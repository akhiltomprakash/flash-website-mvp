---
import "../styles/global.css";

const cards = [
  {
    label: "Records",
    title: "Notes stuck in paper files",
    scatter: { x: -216, y: 5.5195, rotate: -6 },
  },
  {
    label: "Follow-up",
    title: "Follow-ups kept in memory",
    scatter: { x: -98.0164, y: -11.1602, rotate: 5 },
  },
  {
    label: "History",
    title: "Prescriptions in old registers",
    scatter: { x: -100.5703, y: -25.1786, rotate: 4 },
  },
  {
    label: "Vitals",
    title: "Jotted on a nurse's notepad",
    scatter: { x: -287.0283, y: 179, rotate: 5 },
  },
  {
    label: "Reports",
    title: "Lab reports in WhatsApp photos",
    scatter: { x: 271.5664, y: -135.7597, rotate: 6 },
  },
  {
    label: "Medication",
    title: "what they were on lives in three different places",
    scatter: { x: 201.0021, y: -68.043, rotate: -6 },
  },
  {
    label: "Time",
    title: "Doctors searching, not treating",
    scatter: { x: -215, y: -94.7766, rotate: -5 },
  },
  {
    label: "Allergies",
    title: "Known only because one staff member remembers",
    scatter: { x: 52.3672, y: -53, rotate: -1 },
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Flash captures scattered patient notes, prescriptions, reports, and follow-ups into one clear clinical story."
    />
    <title>Flash | Capture Care Faster</title>
  </head>
  <body>
    <main>
      <section class="hero" aria-labelledby="hero-title">
        <nav class="nav" aria-label="Primary navigation">
          <a class="brand" href="/" aria-label="Flash home">
            <img src="/assets/logo.png" alt="Flash" />
          </a>
          <div class="nav-actions">
            <a href="#clinics">For clinics</a>
            <a href="#hospitals">For hospitals</a>
            <a class="nav-demo" href="#demo">Try demo</a>
          </div>
        </nav>

        <div class="hero-copy">
          <div class="hero-kicker" aria-hidden="true">
            <span></span>
            Live clinical memory
          </div>
          <h1 id="hero-title">Capture care faster.<br />Understand patients better.</h1>
          <p>
            Record consultations, prescriptions, reports, and follow-ups in one
            place, then turns patient history into a clear clinical story.
          </p>
        </div>

        <div class="hero-visuals" aria-label="Flash patient management preview">
          <div class="hero-glow" aria-hidden="true"></div>
          <div class="hero-orbit hero-orbit-top" aria-hidden="true">Vitals synced</div>
          <div class="hero-orbit hero-orbit-bottom" aria-hidden="true">Report found</div>
          <img class="doctor-asset" src="/assets/doctor.png" alt="" aria-hidden="true" />
          <img
            class="product-screenshot"
            src="/assets/app-splash.png"
            alt="Flash patient management dashboard showing visits, follow-ups, appointments, and lab trails"
          />
        </div>
        <a class="scroll-cue" href="#patient-title" aria-label="Scroll to patient story">
          <span></span>
        </a>
      </section>

      <section class="patient-story" aria-labelledby="patient-title">
        <div class="story-copy">
          <h2 id="patient-title">Patient information is everywhere</h2>
          <p>A patient's file lives in multiple places and you don’t have the time to gather it before the next visit.</p>
        </div>

        <div class="card-stage" data-card-stage>
          <div class="cards-pin">
            <div class="cards-grid" aria-label="Scattered patient information that gathers into a grid">
              {
                cards.map((card) => (
                  <article
                    class="info-card"
                    data-card-key={card.label.toLowerCase()}
                    style={`--scatter-x:${card.scatter.x}px;--scatter-y:${card.scatter.y}px;--scatter-rotate:${card.scatter.rotate}deg;`}
                  >
                    <span>{card.label}</span>
                    <h3>{card.title}</h3>
                  </article>
                ))
              }
            </div>

            <div class="gather-copy">
              <h2>Flash gathers it for you</h2>
              <p>Every note, prescription, and report, pulled into one patient story, organised and ready before you walk in.</p>
            </div>
          </div>
        </div>

        <section class="workflow-section" aria-labelledby="workflow-title">
          <div class="workflow-feature workflow-feature-scan">
            <div class="workflow-art workflow-art-scan" aria-hidden="true">
              <span class="scan-pulse scan-pulse-a"></span>
              <span class="scan-pulse scan-pulse-b"></span>
              <img src="/assets/scan-it.png" alt="" loading="lazy" />
            </div>
            <div class="workflow-copy workflow-copy-scan" data-feature-copy>
              <span class="feature-copy-accent" aria-hidden="true"></span>
              <h2 id="workflow-title">
                <span class="feature-mask"><span class="feature-reveal-line">Scan it.</span></span>
                <span class="feature-mask"><span class="feature-reveal-line">Get a finished visit</span></span>
              </h2>
              <p>
                <span class="feature-text-mask"><span class="feature-reveal-text">Photograph a handwritten note or an old report.</span></span>
                <span class="feature-text-mask"><span class="feature-reveal-text">Flash reads it and builds the entire visit instantly.</span></span>
              </p>
            </div>
          </div>

          <div class="workflow-feature workflow-feature-caught-up">
            <div class="workflow-copy workflow-copy-caught-up" data-feature-copy>
              <span class="feature-copy-accent" aria-hidden="true"></span>
              <h2>
                <span class="feature-mask"><span class="feature-reveal-line">Skip the catch-up</span></span>
              </h2>
              <p>
                <span class="feature-text-mask"><span class="feature-reveal-text">All relevant patient details are distilled into a paragraph</span></span>
                <span class="feature-text-mask"><span class="feature-reveal-text">and a clear timeline to help you understand it faster than ever.</span></span>
              </p>
            </div>
            <div class="workflow-art workflow-art-caught-up" aria-hidden="true">
              <span class="timeline-spark timeline-spark-a"></span>
              <span class="timeline-spark timeline-spark-b"></span>
              <img src="/assets/already-caught-up.png" alt="" loading="lazy" />
            </div>
          </div>

          <div class="workflow-feature workflow-feature-questions">
            <div class="workflow-copy workflow-copy-questions" data-feature-copy>
              <span class="feature-copy-accent" aria-hidden="true"></span>
              <h2>
                <span class="feature-mask"><span class="feature-reveal-line">Ask it questions.</span></span>
                <span class="feature-mask"><span class="feature-reveal-line">Like a colleague</span></span>
              </h2>
            </div>
            <div class="workflow-art workflow-art-questions" aria-hidden="true">
              <span class="question-ring"></span>
              <img src="/assets/ask-it-questions.png" alt="" loading="lazy" />
            </div>
            <p class="workflow-question-caption" data-feature-caption>
              <span class="feature-text-mask"><span class="feature-reveal-text">Search a patient's entire history in plain language,</span></span>
              <span class="feature-text-mask"><span class="feature-reveal-text">and get instant results.</span></span>
            </p>
          </div>
        </section>
      </section>
    </main>

    <script>
      import gsap from "gsap";
      import { Draggable } from "gsap/Draggable";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(Draggable, ScrollTrigger);

      const cards = gsap.utils.toArray(".info-card");
      const stage = document.querySelector("[data-card-stage]");
      const gatherCopy = document.querySelector(".gather-copy");
      const storageKey = "flash-card-scatter-positions";

      const mm = gsap.matchMedia();

      mm.add("(prefers-reduced-motion: no-preference)", () => {
        const heroTimeline = gsap.timeline({ defaults: { ease: "power3.out" } });

        heroTimeline
          .from(".nav", { y: -18, opacity: 0, duration: 0.65 })
          .from(".hero-kicker", { y: 16, opacity: 0, duration: 0.55 }, "-=0.28")
          .from(".hero-copy h1", { y: 34, opacity: 0, duration: 0.8 }, "-=0.32")
          .from(".hero-copy p", { y: 22, opacity: 0, duration: 0.68 }, "-=0.45")
          .from(".product-screenshot", { y: 70, opacity: 0, scale: 0.94, duration: 0.95 }, "-=0.32")
          .from(".doctor-asset", { x: -58, y: 28, opacity: 0, rotate: -6, duration: 0.78 }, "-=0.52")
          .from(".hero-orbit", { y: 18, opacity: 0, scale: 0.84, stagger: 0.12, duration: 0.54 }, "-=0.42")
          .from(".scroll-cue", { opacity: 0, y: -10, duration: 0.38 }, "-=0.22");

        gsap.to(".product-screenshot", {
          y: -42,
          rotateX: 3,
          scrollTrigger: {
            trigger: ".hero",
            start: "top top",
            end: "bottom top",
            scrub: 0.8,
          },
        });

        gsap.to(".doctor-asset", {
          y: -76,
          rotate: 2,
          scrollTrigger: {
            trigger: ".hero",
            start: "top top",
            end: "bottom top",
            scrub: 0.9,
          },
        });

        gsap.to(".hero-orbit-top", {
          y: -56,
          x: 26,
          scrollTrigger: {
            trigger: ".hero",
            start: "top top",
            end: "bottom top",
            scrub: 1,
          },
        });

        gsap.to(".hero-orbit-bottom", {
          y: -88,
          x: -18,
          scrollTrigger: {
            trigger: ".hero",
            start: "top top",
            end: "bottom top",
            scrub: 1,
          },
        });

        gsap.utils.toArray(".story-copy").forEach((item) => {
          gsap.from(item, {
            autoAlpha: 0,
            y: 44,
            duration: 0.8,
            ease: "power3.out",
            scrollTrigger: {
              trigger: item,
              start: "top 82%",
              once: true,
            },
          });
        });

        gsap.utils.toArray("[data-feature-copy]").forEach((copy) => {
          const feature = copy.closest(".workflow-feature");
          const revealItems = copy.querySelectorAll(".feature-reveal-line, .feature-reveal-text");
          const accent = copy.querySelector(".feature-copy-accent");
          const caption = feature.querySelector("[data-feature-caption]");
          const captionItems = caption?.querySelectorAll(".feature-reveal-text") ?? [];

          const featureTextTimeline = gsap.timeline({
            scrollTrigger: {
              trigger: feature,
              start: "top 72%",
              once: true,
            },
          });

          featureTextTimeline
            .from(accent, {
              scaleX: 0,
              opacity: 0,
              duration: 0.52,
              ease: "power3.out",
              transformOrigin: copy.classList.contains("workflow-copy-caught-up") ? "right center" : "left center",
            })
            .from(revealItems, {
              yPercent: 112,
              opacity: 0,
              rotate: 1.8,
              duration: 0.78,
              stagger: 0.075,
              ease: "power4.out",
            }, "-=0.24")
            .from(captionItems, {
              yPercent: 110,
              opacity: 0,
              duration: 0.64,
              stagger: 0.07,
              ease: "power3.out",
            }, "-=0.28");
        });

        gsap.utils.toArray(".workflow-art").forEach((item) => {
          gsap.from(item, {
            autoAlpha: 0,
            y: 70,
            scale: 0.96,
            duration: 0.95,
            ease: "power3.out",
            scrollTrigger: {
              trigger: item,
              start: "top 84%",
              once: true,
            },
          });
        });

        gsap.to(".workflow-art-scan img", {
          y: -34,
          rotate: -1.2,
          scrollTrigger: {
            trigger: ".workflow-feature-scan",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });

        gsap.to(".workflow-art-caught-up img", {
          y: -42,
          rotate: 1.4,
          scrollTrigger: {
            trigger: ".workflow-feature-caught-up",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });

        gsap.to(".workflow-art-questions img", {
          x: -28,
          scrollTrigger: {
            trigger: ".workflow-feature-questions",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });

        const scatterScale = window.matchMedia("(max-width: 760px)").matches ? 0.52 : 1;
        const easeCards = gsap.parseEase("power2.inOut");
        const savedPositions = JSON.parse(localStorage.getItem(storageKey) || "{}");
        const scatterValues = cards.map((card) => ({
          x: savedPositions[card.dataset.cardKey]?.x ?? Number.parseFloat(card.style.getPropertyValue("--scatter-x")) * scatterScale,
          y: savedPositions[card.dataset.cardKey]?.y ?? Number.parseFloat(card.style.getPropertyValue("--scatter-y")) * scatterScale,
          rotation: Number.parseFloat(card.style.getPropertyValue("--scatter-rotate")),
        }));
        let sceneProgress = 0;

        const setSceneProgress = (progress) => {
          sceneProgress = progress;
          const gatherProgress = gsap.utils.clamp(0, 1, (progress - 0.24) / 0.46);
          const easedProgress = easeCards(gatherProgress);

          cards.forEach((card, index) => {
            const scatter = scatterValues[index];
            gsap.set(card, {
              x: scatter.x * (1 - easedProgress),
              y: scatter.y * (1 - easedProgress),
              rotation: scatter.rotation * (1 - easedProgress),
            });
          });

          gsap.set(gatherCopy, {
            xPercent: -50,
            opacity: gatherProgress,
            y: 90 * (1 - gatherProgress),
          });
        };

        Draggable.create(cards, {
          type: "x,y",
          bounds: ".cards-pin",
          edgeResistance: 0.75,
          cursor: "grab",
          activeCursor: "grabbing",
          zIndexBoost: true,
          onPress() {
            setSceneProgress(0);
          },
          onDrag() {
            const index = cards.indexOf(this.target);
            scatterValues[index].x = this.x;
            scatterValues[index].y = this.y;
          },
          onRelease() {
            const index = cards.indexOf(this.target);
            scatterValues[index].x = this.x;
            scatterValues[index].y = this.y;

            const nextPositions = cards.reduce((positions, card, cardIndex) => {
              positions[card.dataset.cardKey] = {
                x: scatterValues[cardIndex].x,
                y: scatterValues[cardIndex].y,
              };
              return positions;
            }, {});

            localStorage.setItem(storageKey, JSON.stringify(nextPositions));
            window.flashCardPositions = nextPositions;
            setSceneProgress(sceneProgress);
          },
        });

        window.flashCardPositions = cards.reduce((positions, card, cardIndex) => {
          positions[card.dataset.cardKey] = {
            x: scatterValues[cardIndex].x,
            y: scatterValues[cardIndex].y,
          };
          return positions;
        }, {});

        const updateFromScroll = () => {
          const rect = stage.getBoundingClientRect();
          const startOffset = 90;
          const scrollDistance = 360;
          const progress = gsap.utils.clamp(0, 1, (startOffset - rect.top) / scrollDistance);
          setSceneProgress(progress);
        };

        updateFromScroll();
        window.addEventListener("scroll", updateFromScroll, { passive: true });
        window.addEventListener("resize", updateFromScroll);

        return () => {
          window.removeEventListener("scroll", updateFromScroll);
          window.removeEventListener("resize", updateFromScroll);
        };
      });
    </script>
  </body>
</html>
