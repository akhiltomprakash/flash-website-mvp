---
import "../styles/global.css";

const cards = [
  {
    label: "Records",
    title: "Notes stuck in paper files",
    scatter: { x: -216, y: 5.5195, rotate: -6 },
  },
  {
    label: "Follow-up",
    title: "Follow-ups kept in memory",
    scatter: { x: -98.0164, y: -11.1602, rotate: 5 },
  },
  {
    label: "History",
    title: "Prescriptions in old registers",
    scatter: { x: -100.5703, y: -25.1786, rotate: 4 },
  },
  {
    label: "Vitals",
    title: "Jotted on a nurse's notepad",
    scatter: { x: -287.0283, y: 179, rotate: 5 },
  },
  {
    label: "Reports",
    title: "Lab reports in WhatsApp photos",
    scatter: { x: 271.5664, y: -135.7597, rotate: 6 },
  },
  {
    label: "Medication",
    title: "what they were on lives in three different places",
    scatter: { x: 201.0021, y: -68.043, rotate: -6 },
  },
  {
    label: "Time",
    title: "Doctors searching, not treating",
    scatter: { x: -215, y: -94.7766, rotate: -5 },
  },
  {
    label: "Allergies",
    title: "Known only because one staff member remembers",
    scatter: { x: 52.3672, y: -53, rotate: -1 },
  },
];

const platformModules = [
  {
    label: "Patients",
    body: "Keep demographics, visits, prescriptions, reports, notes, and lab orders attached to the patient you are treating.",
  },
  {
    label: "Visits",
    body: "Capture the consultation from vitals and complaints through medicines, tests, files, payment, and follow-up.",
  },
  {
    label: "Prescriptions",
    body: "Create prescriptions from the visit, print them for the patient, and keep every prescription searchable later.",
  },
  {
    label: "Appointments",
    body: "Book, reschedule, and complete appointments so doctors and reception work from the same queue.",
  },
  {
    label: "Billing",
    body: "Track consultation fees, lab-order payments, receipts, and pending balances without a separate ledger.",
  },
  {
    label: "Medicines",
    body: "Watch stock levels, dispensing, and low-stock alerts so the clinic knows what needs attention.",
  },
  {
    label: "Reports",
    body: "Store lab reports, scans, and old prescription images inside the patient record so doctors can review them before deciding care.",
  },
  {
    label: "Analytics",
    body: "See today's visits, payments, activity, and stock alerts so the clinic can spot work that needs follow-up.",
  },
];

const workflowSteps = [
  {
    label: "Front desk",
    title: "Front desk books or finds the patient",
    body: "Reception can search patients, book appointments, manage payments, and keep the queue moving.",
  },
  {
    label: "Patient record",
    title: "Doctor opens the full story",
    body: "Visits, reports, prescriptions, notes, and AI summaries are ready before the consultation starts.",
  },
  {
    label: "Consultation",
    title: "The visit is documented once",
    body: "Vitals, findings, medicines, lab tests, follow-up, files, and billing are captured in the same encounter.",
  },
  {
    label: "Operations",
    title: "The clinic stays synchronized",
    body: "Appointments, prescriptions, inventory, billing, activity logs, and patient history update together.",
  },
];

const faqItems = [
  {
    question: "Can we move from paper or WhatsApp files?",
    answer: "Yes. Flash is built around scanning notes, uploading reports, and turning scattered records into a usable patient timeline.",
  },
  {
    question: "Is AI making decisions?",
    answer: "No. AI creates drafts and suggestions. Doctors review, edit, accept, or ignore them before anything becomes part of care.",
  },
  {
    question: "Can staff use it without seeing clinical controls?",
    answer: "Yes. Reception workflows focus on appointments, patients, and payments, while clinical visit editing stays with doctors.",
  },
  {
    question: "Does it cover more than patient notes?",
    answer: "Yes. The app includes appointments, prescriptions, lab orders, medicine inventory, payments, reports, notes, settings, and analytics.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Flash captures scattered patient notes, prescriptions, reports, and follow-ups into one clear clinical story."
    />
    <title>Flash | Capture Care Faster</title>
  </head>
  <body>
    <main>
      <section class="hero" aria-labelledby="hero-title">
        <nav class="nav" aria-label="Primary navigation">
          <a class="brand" href="/" aria-label="Flash home">
            <img src="/assets/logo.png" alt="Flash" />
          </a>
          <div class="nav-actions">
            <a class="nav-demo" href="#demo">Try demo</a>
          </div>
        </nav>

        <div class="hero-copy">
          <div class="hero-kicker" aria-hidden="true">
            <span></span>
            Live clinical memory
          </div>
          <h1 id="hero-title">Capture care faster.<br />Understand patients better.</h1>
          <p>
            Record consultations, prescriptions, reports, and follow-ups in one
            place, then turn patient history into a clear clinical story.
          </p>
        </div>

        <div class="hero-visuals" aria-label="Flash patient management preview">
          <div class="hero-glow" aria-hidden="true"></div>
          <img class="doctor-asset" src="/assets/doctor.png" alt="" aria-hidden="true" />
          <img
            class="product-screenshot"
            src="/assets/app-splash.png"
            alt="Flash patient management dashboard showing visits, follow-ups, appointments, and lab trails"
          />
        </div>
        <a class="scroll-cue" href="#patient-title" aria-label="Scroll to patient story">
          <span></span>
        </a>
      </section>

      <section class="patient-story" aria-labelledby="patient-title">
        <div class="story-copy">
          <h2 id="patient-title">Patient information is everywhere</h2>
          <p>A patient's file lives in multiple places and you don’t have the time to gather it before the next visit.</p>
        </div>

        <div class="card-stage" data-card-stage>
          <div class="cards-pin">
            <div class="cards-grid" aria-label="Scattered patient information that gathers into a grid">
              {
                cards.map((card) => (
                  <article
                    class="info-card"
                    data-card-key={card.label.toLowerCase()}
                    style={`--scatter-x:${card.scatter.x}px;--scatter-y:${card.scatter.y}px;--scatter-rotate:${card.scatter.rotate}deg;`}
                  >
                    <span>{card.label}</span>
                    <h3>{card.title}</h3>
                  </article>
                ))
              }
            </div>

            <div class="gather-copy">
              <h2>Flash gathers it for you</h2>
              <p>Every note, prescription, and report, pulled into one patient story, organised and ready before you walk in.</p>
            </div>
          </div>
        </div>

        <section class="workflow-section" aria-labelledby="workflow-title">
          <div class="workflow-feature workflow-feature-scan">
            <div class="workflow-art workflow-art-scan" aria-hidden="true">
              <img src="/assets/scan-it.png" alt="" loading="lazy" />
            </div>
            <div class="workflow-copy workflow-copy-scan" data-feature-copy>
              <span class="feature-copy-accent" aria-hidden="true"></span>
              <h2 id="workflow-title">
                <span class="feature-mask"><span class="feature-reveal-line">Scan it.</span></span>
                <span class="feature-mask"><span class="feature-reveal-line">Get a finished visit</span></span>
              </h2>
              <p>
                <span class="feature-text-mask"><span class="feature-reveal-text">Snap a handwritten note, and build a finished visit in a flash.</span></span>
              </p>
            </div>
          </div>

          <div class="workflow-feature workflow-feature-caught-up">
            <div class="workflow-copy workflow-copy-caught-up" data-feature-copy>
              <span class="feature-copy-accent" aria-hidden="true"></span>
              <h2>
                <span class="feature-mask"><span class="feature-reveal-line">Skip the catch-up</span></span>
              </h2>
              <p>
                <span class="feature-text-mask"><span class="feature-reveal-text">Get and understand patient history in seconds from anywhere.</span></span>
              </p>
            </div>
            <div class="workflow-art workflow-art-caught-up" aria-hidden="true">
              <img src="/assets/already-caught-up.png" alt="" loading="lazy" />
            </div>
          </div>

          <div class="workflow-feature workflow-feature-questions">
            <div class="workflow-copy workflow-copy-questions" data-feature-copy>
              <span class="feature-copy-accent" aria-hidden="true"></span>
              <h2>
                <span class="feature-mask"><span class="feature-reveal-line">Ask it questions.</span></span>
                <span class="feature-mask"><span class="feature-reveal-line">Like a colleague</span></span>
              </h2>
            </div>
            <div class="workflow-art workflow-art-questions" aria-hidden="true">
              <video
                class="ask-it-video"
                autoplay
                loop
                muted
                playsinline
                preload="metadata"
              >
                <source src="/assets/ask-it-questions.mp4" type="video/mp4" />
              </video>
            </div>
            <p class="workflow-question-caption" data-feature-caption>
              <span class="feature-text-mask"><span class="feature-reveal-text">Ask it anything related to your patients and get instant answers.</span></span>
            </p>
          </div>
        </section>

        <section class="platform-section" aria-labelledby="platform-title">
          <div class="section-heading">
            <h2 id="platform-title" class="platform-title">Complete patient workspace</h2>
          </div>

          <div class="module-tabs" aria-label="Flash platform modules">
            {
              platformModules.map((module) => (
                <article class="module-card">
                  <h3>{module.label}</h3>
                  <p>{module.body}</p>
                </article>
              ))
            }
          </div>
        </section>

        <section class="clinic-flow" aria-labelledby="flow-title">
          <div class="section-heading">
            <h2 id="flow-title">From appointment to follow-up without losing context.</h2>
          </div>

          <div class="flow-map" aria-label="Flash daily clinic flow">
            <div class="flow-rail" aria-hidden="true">
              <span></span>
            </div>

            <div class="flow-steps">
              {
                workflowSteps.map((step, index) => (
                  <article class="flow-step" style={`--flow-x:${[0, 290, 580, 870][index]}px;--flow-y:${[18, 56, 96, 120][index]}px;`}>
                    <div class="flow-node" aria-hidden="true">{String(index + 1).padStart(2, "0")}</div>
                    <div class="flow-step-copy">
                      <span>{step.label}</span>
                      <h3>{step.title}</h3>
                      <p>{step.body}</p>
                    </div>
                  </article>
                ))
              }
            </div>
          </div>

          <div class="flow-qa" aria-label="Clinic switching questions">
            {
              faqItems.map((item) => (
                <details class="qa-item">
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                </details>
              ))
            }
          </div>
        </section>

        <section class="final-cta" id="demo" aria-labelledby="demo-title">
          <div>
            <span>See Flash in clinic mode</span>
            <h2 id="demo-title">Walk through a real patient, appointment, visit, prescription, and bill.</h2>
            <p>
              Use the demo to see how Flash handles the everyday work of a clinic,
              not just the tidy parts of the record.
            </p>
          </div>
          <a href="mailto:hello@flash.care?subject=Flash%20demo%20request">Book a demo</a>
        </section>
      </section>
    </main>

    <script>
      import gsap from "gsap";
      import { Draggable } from "gsap/Draggable";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(Draggable, ScrollTrigger);

      const cards = gsap.utils.toArray(".info-card");
      const stage = document.querySelector("[data-card-stage]");
      const gatherCopy = document.querySelector(".gather-copy");
      const storageKey = "flash-card-scatter-positions";

      const mm = gsap.matchMedia();

      mm.add("(prefers-reduced-motion: no-preference)", () => {
        const heroTimeline = gsap.timeline({ defaults: { ease: "power3.out" } });

        heroTimeline
          .from(".nav", { y: -18, opacity: 0, duration: 0.65 })
          .from(".hero-kicker", { y: 16, opacity: 0, duration: 0.55 }, "-=0.28")
          .from(".hero-copy h1", { y: 34, opacity: 0, duration: 0.8 }, "-=0.32")
          .from(".hero-copy p", { y: 22, opacity: 0, duration: 0.68 }, "-=0.45")
          .from(".product-screenshot", { y: 70, opacity: 0, scale: 0.94, duration: 0.95 }, "-=0.32")
          .from(".doctor-asset", { x: -58, y: 28, opacity: 0, rotate: -6, duration: 0.78 }, "-=0.52")
          .from(".scroll-cue", { opacity: 0, y: -10, duration: 0.38 }, "-=0.22");

        gsap.to(".product-screenshot", {
          y: -42,
          rotateX: 3,
          scrollTrigger: {
            trigger: ".hero",
            start: "top top",
            end: "bottom top",
            scrub: 0.8,
          },
        });

        gsap.to(".doctor-asset", {
          y: -76,
          rotate: 2,
          scrollTrigger: {
            trigger: ".hero",
            start: "top top",
            end: "bottom top",
            scrub: 0.9,
          },
        });

        gsap.utils.toArray(".story-copy").forEach((item) => {
          gsap.from(item, {
            autoAlpha: 0,
            y: 44,
            duration: 0.8,
            ease: "power3.out",
            scrollTrigger: {
              trigger: item,
              start: "top 82%",
              once: true,
            },
          });
        });

        gsap.utils.toArray("[data-feature-copy]").forEach((copy) => {
          const feature = copy.closest(".workflow-feature");
          const revealItems = copy.querySelectorAll(".feature-reveal-line, .feature-reveal-text");
          const accent = copy.querySelector(".feature-copy-accent");
          const caption = feature.querySelector("[data-feature-caption]");
          const captionItems = caption?.querySelectorAll(".feature-reveal-text") ?? [];

          const featureTextTimeline = gsap.timeline({
            scrollTrigger: {
              trigger: feature,
              start: "top 72%",
              once: true,
            },
          });

          featureTextTimeline
            .from(accent, {
              scaleX: 0,
              opacity: 0,
              duration: 0.52,
              ease: "power3.out",
              transformOrigin: copy.classList.contains("workflow-copy-caught-up") ? "right center" : "left center",
            })
            .from(revealItems, {
              yPercent: 112,
              opacity: 0,
              rotate: 1.8,
              duration: 0.78,
              stagger: 0.075,
              ease: "power4.out",
            }, "-=0.24")
            .from(captionItems, {
              yPercent: 110,
              opacity: 0,
              duration: 0.64,
              stagger: 0.07,
              ease: "power3.out",
            }, "-=0.28");
        });

        gsap.utils.toArray(".workflow-art").forEach((item) => {
          gsap.from(item, {
            autoAlpha: 0,
            y: 70,
            scale: 0.96,
            duration: 0.95,
            ease: "power3.out",
            scrollTrigger: {
              trigger: item,
              start: "top 84%",
              once: true,
            },
          });
        });

        gsap.to(".workflow-art-scan img", {
          y: -34,
          rotate: -1.2,
          scrollTrigger: {
            trigger: ".workflow-feature-scan",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });

        gsap.to(".workflow-art-caught-up img", {
          y: -42,
          rotate: 1.4,
          scrollTrigger: {
            trigger: ".workflow-feature-caught-up",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });

        gsap.to(".ask-it-video", {
          scrollTrigger: {
            trigger: ".workflow-feature-questions",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });

        gsap.from(".flow-step", {
          autoAlpha: 0,
          y: 44,
          rotate: -0.8,
          duration: 0.72,
          stagger: 0.11,
          ease: "power3.out",
          scrollTrigger: {
            trigger: ".flow-map",
            start: "top 76%",
            once: true,
          },
        });

        gsap.from(".flow-rail span", {
          scaleX: 0,
          duration: 1.05,
          ease: "power3.inOut",
          transformOrigin: "left center",
          scrollTrigger: {
            trigger: ".flow-map",
            start: "top 76%",
            once: true,
          },
        });

        const scatterScale = window.matchMedia("(max-width: 760px)").matches ? 0.52 : 1;
        const easeCards = gsap.parseEase("power2.inOut");
        const savedPositions = JSON.parse(localStorage.getItem(storageKey) || "{}");
        const scatterValues = cards.map((card) => ({
          x: savedPositions[card.dataset.cardKey]?.x ?? Number.parseFloat(card.style.getPropertyValue("--scatter-x")) * scatterScale,
          y: savedPositions[card.dataset.cardKey]?.y ?? Number.parseFloat(card.style.getPropertyValue("--scatter-y")) * scatterScale,
          rotation: Number.parseFloat(card.style.getPropertyValue("--scatter-rotate")),
        }));
        let sceneProgress = 0;

        const setSceneProgress = (progress) => {
          sceneProgress = progress;
          const gatherProgress = gsap.utils.clamp(0, 1, (progress - 0.24) / 0.46);
          const easedProgress = easeCards(gatherProgress);

          cards.forEach((card, index) => {
            const scatter = scatterValues[index];
            gsap.set(card, {
              x: scatter.x * (1 - easedProgress),
              y: scatter.y * (1 - easedProgress),
              rotation: scatter.rotation * (1 - easedProgress),
            });
          });

          gsap.set(gatherCopy, {
            xPercent: -50,
            opacity: gatherProgress,
            y: 90 * (1 - gatherProgress),
          });
        };

        Draggable.create(cards, {
          type: "x,y",
          bounds: ".cards-pin",
          edgeResistance: 0.75,
          cursor: "grab",
          activeCursor: "grabbing",
          zIndexBoost: true,
          onPress() {
            setSceneProgress(0);
          },
          onDrag() {
            const index = cards.indexOf(this.target);
            scatterValues[index].x = this.x;
            scatterValues[index].y = this.y;
          },
          onRelease() {
            const index = cards.indexOf(this.target);
            scatterValues[index].x = this.x;
            scatterValues[index].y = this.y;

            const nextPositions = cards.reduce((positions, card, cardIndex) => {
              positions[card.dataset.cardKey] = {
                x: scatterValues[cardIndex].x,
                y: scatterValues[cardIndex].y,
              };
              return positions;
            }, {});

            localStorage.setItem(storageKey, JSON.stringify(nextPositions));
            window.flashCardPositions = nextPositions;
            setSceneProgress(sceneProgress);
          },
        });

        window.flashCardPositions = cards.reduce((positions, card, cardIndex) => {
          positions[card.dataset.cardKey] = {
            x: scatterValues[cardIndex].x,
            y: scatterValues[cardIndex].y,
          };
          return positions;
        }, {});

        const updateFromScroll = () => {
          const rect = stage.getBoundingClientRect();
          const startOffset = 90;
          const scrollDistance = 360;
          const progress = gsap.utils.clamp(0, 1, (startOffset - rect.top) / scrollDistance);
          setSceneProgress(progress);
        };

        updateFromScroll();
        window.addEventListener("scroll", updateFromScroll, { passive: true });
        window.addEventListener("resize", updateFromScroll);

        return () => {
          window.removeEventListener("scroll", updateFromScroll);
          window.removeEventListener("resize", updateFromScroll);
        };
      });
    </script>
  </body>
</html>
